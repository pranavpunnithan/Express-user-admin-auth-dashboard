<!DOCTYPE html>
<html>
<head>
    <title>Admin Dashboard</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<div class="dashboard-page">
    <div class="dashboard">
        <div class="dashboard-header">
            <h2>Admin Dashboard</h2>
            <a class="dashboard-logout" href="/admin/logout">Logout</a>
        </div>

        <form class="dashboard-search" method="GET" action="/admin/dashboard">
            <input type="text" name="search" placeholder="Search email" value="<%= search %>">
            <button type="submit">Search</button>
        </form>

        <table>
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Actions</th>
            </tr>

            <% users.forEach(user => { %>
                <tr>
                    <td><%= user.name %></td>
                    <td><%= user.email %></td>
                    <td class="dashboard-actions">
                        <a href="/admin/edit/<%= user._id %>">Edit</a>
                        <a class="danger" href="/admin/delete/<%= user._id %>">Delete</a>
                    </td>
                </tr>
            <% }) %>
        </table>
    </div>
</div>

</body>
</html>
